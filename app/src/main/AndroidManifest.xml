<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- USB host mode: the phone acts as the host and the Nano as the device -->
    <uses-feature android:name="android.hardware.usb.host" android:required="true" />

    <!-- Camera for VLM image capture -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature android:name="android.hardware.camera.any" android:required="false" />

    <!-- Internet for VLM API calls -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!--
      usesCleartextTraffic: permits http:// URLs for self-hosted VLM servers (Ollama etc.)
      reached over a Tailscale/WireGuard tunnel or trusted LAN. The tunnel provides the
      transport encryption in that setup. Public endpoints should still use https://.
    -->
    <application
        android:allowBackup="false"
        android:icon="@drawable/ic_launcher_foreground"
        android:label="@string/app_name"
        android:roundIcon="@drawable/ic_launcher_foreground"
        android:supportsRtl="true"
        android:theme="@style/Theme.Strix"
        android:usesCleartextTraffic="true">

        <!--
          On Android 12+ (API 31+), apps must declare vendor native libraries they load.
          The on-device VLM's vision pipeline uses a TFLite OpenCL GPU delegate; without
          these entries, dlopen of the vendor OpenCL driver fails with
          "libvndksupport.so not found" and session creation aborts.
        -->
        <uses-native-library android:name="libOpenCL.so" android:required="false" />
        <uses-native-library android:name="libOpenCL-car.so" android:required="false" />
        <uses-native-library android:name="libOpenCL-pixel.so" android:required="false" />

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize">

            <!-- Normal launcher intent -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!--
              Auto-launch when the Nano is plugged in.
              The device filter in res/xml/usb_device_filter.xml targets the CH340
              clone (vendor 0x1A86 / product 0x7523) used on most Arduino Nano clones.
            -->
            <intent-filter>
                <action android:name="android.hardware.usb.action.USB_DEVICE_ATTACHED" />
            </intent-filter>
            <meta-data
                android:name="android.hardware.usb.action.USB_DEVICE_ATTACHED"
                android:resource="@xml/usb_device_filter" />

        </activity>
    </application>
</manifest>
